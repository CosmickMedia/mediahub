# Configuration files
config.php
!lib/config.php

# Service account credentials - NEVER commit these!
service-account.json
cosmickmedia-*.json

# Allow package.json to be tracked for CI build
!package.json
# Ignore all other JSON files
#*.json

# Temporary files
/tmp/
*.tmp

# IDE files
.idea/
.vscode/
*.sublime-*

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
error_log

# Uploaded files (if stored locally)
uploads/
public/uploads/

# Backup files
*.bak
*.backup
*~

# PHP specific
vendor/
# …but track our in-repo browser asset vendor dir (ffmpeg.wasm, etc.).
# The production deploy needs these files; they aren't pulled by any
# package manager. Without them the MOV→MP4 transcoder 404s at runtime.
!assets/vendor/
composer.lock
.user.ini
/assets/thumbs/
/assets/thumbs/
